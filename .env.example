# URL pública donde se sirve la app del widget (Next.js)
NEXT_PUBLIC_WIDGET_URL=https://widget.cpiq.com

# URL del panel externo al que el widget redirige
NEXT_PUBLIC_PANEL_URL=https://panel.cpiq.com

# Hosts autorizados a embeber el widget (CSP frame-ancestors).
# Usar espacios o comas para separar. Dejar vacío para permitir todos (*).
# Ejemplo: "https://cpiq.com https://www.cpiq.com"
NEXT_PUBLIC_ALLOWED_HOSTS=

# Versión lógica del widget — usada como cache buster en loader.js → widget.js
NEXT_PUBLIC_WIDGET_VERSION=1
